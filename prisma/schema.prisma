generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Price {
  id            String   @id @default(uuid())
  scheduleId    String
  priceValue    Int
  priceCurrency String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("prices")
}

model Tour {
  id          String  @id @default(uuid())
  title       String
  slug        String
  description String
  isAlive     Boolean
}

model Schedule {
  id        String   @id @default(uuid())
  productId String
  isActive  Boolean
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
